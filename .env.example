# Mneme Configuration
# Copy this file to .env and fill in your keys

# ── LLM Providers (Three-tier strategy, June 2026) ────────────────────────
#
# Tier 1 (cloud LLM) — MiniMax M2.7:
#   LLM-assisted chunking by boundary definition + general inference.
#   JSON-reliable on long inputs, faster than the old MiniMax-Text-01.
# Tier 2 (cloud embeddings) — Gemini Embedding 2:
#   Dense vector embeddings (768-dim default) for semantic similarity search.
# Tier 3 (local LLM) — BitNet b1.58-2B-4T:
#   Intent detection on-device, OpenAI-compatible HTTP at :8081.
#

# ── Tier 1: MiniMax (LLM chunking + inference) ────────────────────────────
MINIMAX_API_KEY=your_m...here
MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_MODEL=MiniMax-M2.7

# ── Tier 2: Embeddings (June 19 2026 — default = local Ollama) ────────────
# Set EMBEDDING_PROVIDER=ollama to use local qwen3-embedding:0.6b (no rate limits)
# Set EMBEDDING_PROVIDER=gemini to fall back to Gemini Embedding 2 (cloud, 100 RPM cap)
EMBEDDING_PROVIDER=ollama

# Ollama (local embeddings — default Tier 2)
# Pull model first: ollama pull qwen3-embedding:0.6b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=qwen3-embedding:0.6b
OLLAMA_EMBEDDING_DIM=1024

# Gemini (cloud embeddings — fallback Tier 2, requires GEMINI_API_KEY)
GEMINI_API_KEY=your_g...here
GEMINI_API_KEY_FALLBACK=                   # optional second key for rotation
GEMINI_EMBEDDING_MODEL=gemini-embedding-2
EMBEDDING_DIM=768                           # 768 default (3072 native)
EMBEDDING_BATCH_SIZE=50                     # vectors per batched embed call

# Anthropic-compatible API key (legacy fallback, optional)
# ANTHROPIC_API_KEY=your_a...here

# ── Vector Search ────────────────────────────────────────────────────────────

# Qdrant (local by default)
QDRANT_HOST=http://localhost:6333
QDRANT_COLLECTION=mneme_chunks

# ── Graph Database ────────────────────────────────────────────────────────────

# Neo4j (local by default)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here

# ── Ollama (local intent detection) ─────────────────────────────────────────

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=phi-4-mini  # or any 100-200M model you have pulled

# ── Local LLM server (BitNet llama-server, OpenAI-compatible) ────────────────
# Start with: ./scripts/start-llm-server.sh
# Stop with:  kill $(lsof -ti :8081)

BITNET_HOST=localhost                  # bind host of llama-server
BITNET_PORT=8081                       # listen port (must match docker-compose)
BITNET_MODEL=falcon3-1b-instruct       # model alias registered with the server
# BITNET_DISABLED=1                    # set to 1 to skip LLM calls, use keyword fallback

# ── Server ───────────────────────────────────────────────────────────────────

MNEME_HOST=localhost
MNEME_PORT=8080

# ── Ingest path allowlist ────────────────────────────────────────────────────
# Comma-separated list of directories that POST /ingest is allowed to read from.
# When unset, a loud warning is logged and ALL paths are accepted (dev mode).
# When set, any file_path (literal or glob match) that resolves outside these
# roots is rejected with HTTP 403. Path.resolve() defeats symlink traversal.
# MNEME_INGEST_ALLOWED_ROOTS=/home/user/projects,/srv/code
